---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/Icon.astro';
import Badge from '../../components/Badge.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Section from '../../components/Section.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Callout from '../../components/Callout.astro';
import LessonNav from '../../components/LessonNav.astro';
import CompleteButton from '../../components/CompleteButton.astro';
import { findLesson } from '../../data/sql';
import { withBase } from '../../utils/paths';

const lesson = findLesson('proyecto-final')!;

const STATUS_BADGE = {
  pending:       { label: 'Pendiente',  variant: 'muted' as const,   dot: false },
  'in-progress': { label: 'En curso',   variant: 'primary' as const, dot: true },
  completed:     { label: 'Completada', variant: 'sql' as const,     dot: false },
};
const status = STATUS_BADGE[lesson.status];
---

<DocsLayout
  title="Proyecto Final · Sistema de Gestión de Biblioteca — Apuntes SQL"
  activeSlug="proyecto-final"
>
  <div class="docs__inner docs__layout">
    <article class="docs__article">
      <Breadcrumbs items={[
        { label: 'Apuntes SQL', href: withBase('/') },
        { label: `Tema ${lesson.topicNumber} · ${lesson.topic}`, href: withBase(`/#tema-${lesson.topicNumber}`) },
        { label: 'Proyecto Final' },
      ]} />

      <div class="class-meta" style="margin-top: 1rem;">
        {lesson.status !== 'pending' && <Badge variant={status.variant} dot={status.dot}>{status.label}</Badge>}
        <Badge variant="warn"><Icon name="trophy" size={10} />Proyecto final</Badge>
        <span class="chip">Clase {lesson.classNumber}</span>
        <span class="chip">Tema {lesson.topicNumber}</span>
      </div>

      <h1 class="class-title">{lesson.title}</h1>

      {lesson.summary && <p class="class-lead">{lesson.summary}</p>}

      {lesson.tags.length > 0 && (
        <div class="class-tags">
          {lesson.tags.map((tag) => <span class="chip">#{tag}</span>)}
        </div>
      )}

      {/* 01 — RESUMEN */}
      <Section id="resumen" title="Resumen rápido" eyebrow="01">
        <p class="lesson-prose__p">{lesson.summary}</p>
      </Section>

      {/* 02 — CONCEPTOS CLAVE */}
      <Section id="conceptos" title="Conceptos clave" eyebrow="02">
        <div class="concepts-grid">
          {lesson.keyConcepts.map((kc) => (
            <div class="card concept-card">
              <div class="concept-card__fn">{kc.term}</div>
              <p class="concept-card__desc">{kc.definition}</p>
            </div>
          ))}
        </div>
      </Section>

      {/* 03 — CONTENIDO */}
      <Section id="contenido" title="Contenido de la clase" eyebrow="03">
        <div class="lesson-prose">
          {lesson.contenido.map((section) => (
            <div class="lesson-prose__section">
              {section.heading && <h3 class="lesson-prose__h3">{section.heading}</h3>}
              {section.blocks.map((block) => (
                <>
                  {block.type === 'p' && (
                    <p class="lesson-prose__p">{block.text}</p>
                  )}
                  {block.type === 'ul' && (
                    <ul class="lesson-prose__list">
                      {block.items.map((item) => <li>{item}</li>)}
                    </ul>
                  )}
                  {block.type === 'ol' && (
                    <ol class="lesson-prose__list lesson-prose__list--ol">
                      {block.items.map((item) => <li>{item}</li>)}
                    </ol>
                  )}
                  {block.type === 'callout' && (
                    <Callout type={block.variant} title={block.title}>
                      {block.text}
                    </Callout>
                  )}
                  {block.type === 'table' && (
                    <div class="lesson-prose__table-wrap">
                      <table class="lesson-prose__table">
                        <thead>
                          <tr>
                            {block.headers.map((h) => <th>{h}</th>)}
                          </tr>
                        </thead>
                        <tbody>
                          {block.rows.map((row) => (
                            <tr>
                              {row.map((cell) => <td>{cell}</td>)}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </>
              ))}
            </div>
          ))}
        </div>
      </Section>

      {/* 04 — CÓDIGO Y EJEMPLOS */}
      <Section id="codigo" title="Código y ejemplos" eyebrow="04">
        <div class="code-examples">
          {lesson.codeExamples.map((ex) => (
            <div class="code-example">
              {ex.label && <p class="code-example__label">{ex.label}</p>}
              <CodeBlock code={ex.code} lang={ex.lang ?? 'sql'} />
              {ex.note && <p class="code-example__note">{ex.note}</p>}
            </div>
          ))}
        </div>
      </Section>

      {/* 05 — ERRORES COMUNES */}
      <Section id="errores" title="Errores comunes" eyebrow="05">
        <div class="insight-cards">
          {lesson.errores.map((e) => (
            <div class="insight-card insight-card--err">
              <span class="insight-card__ico" aria-hidden="true">x</span>
              <span>{e}</span>
            </div>
          ))}
        </div>
      </Section>

      {/* 06 — BUENAS PRÁCTICAS */}
      <Section id="practicas" title="Buenas prácticas" eyebrow="06">
        <div class="insight-cards">
          {lesson.practicas.map((p) => (
            <div class="insight-card insight-card--tip">
              <span class="insight-card__ico" aria-hidden="true">✓</span>
              <span>{p}</span>
            </div>
          ))}
        </div>
      </Section>

      {/* 07 — EJERCICIOS */}
      <Section id="ejercicios" title="Ejercicios" eyebrow="07">
        <ol class="lesson-prose__list lesson-prose__list--ol">
          {lesson.ejercicios.map((e) => <li>{e}</li>)}
        </ol>
      </Section>

      {/* 08 — CHECKLIST */}
      <Section id="checklist" title="Checklist final" eyebrow="08">
        <ul class="lesson-checklist">
          {lesson.checklist.map((item) => (
            <li class="lesson-checklist__item">
              <span class="lesson-checklist__box" aria-hidden="true" />
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </Section>

      <LessonNav prevSlug={lesson.previousSlug} nextSlug={lesson.nextSlug} />

      <div style="margin-top: 1.25rem;">
        <CompleteButton slug={lesson.slug} />
      </div>
    </article>

    <!-- TOC -->
    <aside class="toc" aria-label="Índice de la clase">
      <p class="toc__title">En esta clase</p>
      <a class="toc__link" href="#resumen">Resumen rápido</a>
      <a class="toc__link" href="#conceptos">Conceptos clave</a>
      <a class="toc__link" href="#contenido">Contenido</a>
      <a class="toc__link" href="#codigo">Código y ejemplos</a>
      <a class="toc__link" href="#errores">Errores comunes</a>
      <a class="toc__link" href="#practicas">Buenas prácticas</a>
      <a class="toc__link" href="#ejercicios">Ejercicios</a>
      <a class="toc__link" href="#checklist">Checklist</a>
    </aside>
  </div>
</DocsLayout>

<script>
  const sections = Array.from(document.querySelectorAll<HTMLElement>('article.docs__article section.section'));
  const links = new Map<string, HTMLAnchorElement>();
  document.querySelectorAll<HTMLAnchorElement>('.toc .toc__link').forEach((a) => {
    const id = a.getAttribute('href')?.slice(1);
    if (id) links.set(id, a);
  });

  if (sections.length && links.size) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = links.get(entry.target.id);
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('is-active'));
            link.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-30% 0px -55% 0px', threshold: 0 },
    );
    sections.forEach((s) => observer.observe(s));
  }
</script>
