---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/Icon.astro';
import Badge from '../../components/Badge.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Section from '../../components/Section.astro';
import EmptyState from '../../components/EmptyState.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import { findLesson } from '../../data/sql';

const lesson = findLesson('proyecto-final')!;

const sections = [
  { id: 'objetivo',     n: '01', title: 'Objetivo del proyecto',  empty: 'Objetivo pendiente de definir con el enunciado real.' },
  { id: 'requisitos',   n: '02', title: 'Requisitos funcionales', empty: 'Listado de requisitos pendiente de añadir.' },
  { id: 'modelo',       n: '03', title: 'Modelo de datos',        empty: 'Diagrama del modelo pendiente de añadir.' },
  { id: 'tablas',       n: '04', title: 'Tablas necesarias',      empty: 'Listado de tablas pendiente de añadir.' },
  { id: 'relaciones',   n: '05', title: 'Relaciones',             empty: 'Definición de relaciones pendiente.' },
  { id: 'consultas',    n: '06', title: 'Consultas obligatorias', empty: 'Consultas obligatorias pendientes de definir.' },
  { id: 'entrega',      n: '07', title: 'Checklist de entrega',   empty: 'Checklist de entrega pendiente de definir.' },
  { id: 'mejoras',      n: '08', title: 'Mejoras opcionales',     empty: 'Mejoras opcionales pendientes de definir.' },
  { id: 'final',        n: '09', title: 'Entrega final',          empty: 'Instrucciones de entrega pendientes.' },
];
---

<DocsLayout
  title="Proyecto Final · Sistema de Gestión de Biblioteca — Apuntes SQL"
  activeSlug="proyecto-final"
>
  <!-- Hero -->
  <section class="fp-hero" aria-labelledby="fp-title">
    <div class="fp-hero__grid-bg" aria-hidden="true" />

    <div class="fp-hero__inner">
      <span class="fp-hero__badge" aria-hidden="true">
        <Icon name="trophy" size={40} />
      </span>

      <div class="fp-hero__body">
        <Breadcrumbs items={[
          { label: 'Apuntes SQL', href: '/' },
          { label: `Tema ${lesson.topicNumber} · ${lesson.topic}`, href: `/#tema-${lesson.topicNumber}` },
          { label: 'Proyecto Final' },
        ]} />

        <div class="fp-hero__chips" style="margin-top: 1rem;">
          <Badge variant="warn"><Icon name="trophy" size={10} />Proyecto final</Badge>
          <Badge variant="muted">Clase {lesson.classNumber}</Badge>
          <Badge variant="sql"><Icon name="flag" size={10} />Cierre del temario</Badge>
        </div>

        <h1 id="fp-title" class="fp-hero__title">
          Sistema de Gestión<br />
          <span class="fp-hero__title-accent">de Biblioteca</span>
        </h1>

        <p class="fp-hero__lead">
          Cierre del módulo de SQL. El enunciado, el modelo de datos, las consultas
          obligatorias y los criterios de entrega se publicarán cuando se importe
          el contenido real de la clase. Esta página deja la estructura visual
          preparada para recibirlos.
        </p>

        <div class="fp-hero__stats">
<span><Icon name="chart" size={14} />Dificultad <strong style="color: var(--warn);">Avanzada</strong></span>
          <span><Icon name="table" size={14} />Modelo <strong>pendiente</strong></span>
          <span><Icon name="code" size={14} />Consultas <strong>pendientes</strong></span>
        </div>
      </div>

      <div class="fp-hero__cta">
        <button type="button" class="btn btn--primary" disabled aria-disabled="true">
          <Icon name="play" size={11} />
          Empezar proyecto
        </button>
        <button type="button" class="btn btn--ghost" disabled aria-disabled="true">
          <Icon name="bookmark" size={13} />
          Guardar
        </button>
      </div>
    </div>
  </section>

  <div class="fp-body">
    <!-- Objetivo + Aprenderás (placeholders) -->
    <div class="fp-twocol">
      <div class="card">
        <p class="eyebrow" style="color: var(--warn); margin-bottom: 0.625rem;">
          <Icon name="flag" size={11} /> Objetivo
        </p>
        <EmptyState
          title="Objetivo pendiente"
          text="El enunciado y el alcance del proyecto se publicarán cuando se importe la clase 08 real."
        />
      </div>
      <div class="card">
        <p class="eyebrow" style="color: var(--sql); margin-bottom: 0.625rem;">
          <Icon name="spark" size={11} /> Aprenderás a
        </p>
        <EmptyState
          title="Objetivos de aprendizaje pendientes"
          text="Esta lista se completará junto al enunciado real del proyecto final."
        />
      </div>
    </div>

    {sections.map((s) => (
      <Section id={s.id} title={s.title} eyebrow={s.n}>
        {s.id === 'consultas' ? (
          <CodeBlock empty emptyText="Las consultas obligatorias se publicarán como bloques de código cuando se importe el enunciado real." />
        ) : s.id === 'modelo' ? (
          <div class="card" style="padding: 0;">
            <EmptyState
              title="Diagrama del modelo de datos pendiente"
              text="El diagrama relacional con las tablas y relaciones se añadirá tras la importación de la clase real."
              icon="table"
            />
          </div>
        ) : s.id === 'requisitos' || s.id === 'tablas' ? (
          <div class="fp-rf-grid">
            {[1, 2, 3, 4].map(() => (
              <div class="card empty empty--compact">
                <span class="empty__ico" aria-hidden="true"><Icon name="sparkle" size={16} /></span>
                <div class="empty__body">
                  <p class="empty__title">Pendiente</p>
                  <p class="empty__text">Se completará con el contenido real.</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <EmptyState title={s.empty} />
        )}
      </Section>
    ))}

    <div class="fp-final-cta">
      <Icon name="trophy" size={36} />
      <div class="fp-final-cta__body">
        <h3 class="h3 fp-final-cta__title">Cierre del temario por todo lo alto</h3>
        <p class="fp-final-cta__sub">
          Al importar el enunciado real del proyecto, esta página se completará
          con requisitos, modelo de datos, consultas obligatorias y checklist de entrega.
        </p>
      </div>
      <a class="btn btn--ghost" href="/">
        <Icon name="arrow-left" size={11} />
        Volver al temario
      </a>
    </div>
  </div>
</DocsLayout>
