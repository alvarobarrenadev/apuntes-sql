---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  activeSlug?: string | null;
  showFooter?: boolean;
}

const { title, description, activeSlug = null, showFooter = false } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  withSidebarToggle
  showFooter={showFooter}
>
  <div class="docs">
    <Sidebar activeSlug={activeSlug} />
    <div class="docs__main">
      <slot />
    </div>
  </div>
</BaseLayout>
