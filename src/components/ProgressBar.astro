---
interface Props {
  value: number;
  max?: number;
  label?: string;
  showMeta?: boolean;
}

const { value, max = 100, label = 'Progreso', showMeta = true } = Astro.props;
const pct = Math.max(0, Math.min(100, Math.round((value / max) * 100)));
---

<div class="progress">
  <div
    class="progress__bar"
    role="progressbar"
    aria-valuenow={value}
    aria-valuemin="0"
    aria-valuemax={max}
    aria-label={label}
  >
    <span class="progress__fill" style={`width: ${pct}%`} />
  </div>
  {showMeta && (
    <div class="progress__meta">
      <span>{label}</span>
      <span>{pct}%</span>
    </div>
  )}
</div>
